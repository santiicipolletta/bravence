# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
# Si no tienes Mongo instalado, esto dará error de conexión pero la web se verá.
MONGODB_URI=mongodb://localhost:27017/bravence

# Email Configuration (Ejemplo Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-contraseña-de-aplicacion
ADMIN_EMAIL=contacto@bravence.com

# Admin API Key
ADMIN_API_KEY=clave1234